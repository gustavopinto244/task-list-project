<%- include('includes/head') %>
<%- include('includes/nav') %>

<div class="container my-5">
  <div class="row">
    <div class="col-lg-8 offset-lg-2">
      <!-- Header -->
      <div class="mb-5">
        <h1 class="display-4">✓ Task List</h1>
        <p class="lead text-muted">Organize and track your daily tasks</p>
      </div>

      <!-- Add Task Form -->
      <div class="card mb-4 border-0 shadow-sm">
        <div class="card-body">
          <form method="POST" class="row g-2">
            <div class="col-md-7">
              <input type="text" class="form-control form-control-lg" placeholder="Add a new task..." required>
            </div>
            <div class="col-md-3">
              <select class="form-select form-select-lg">
                <option value="">Priority</option>
                <option value="high">🔴 High</option>
                <option value="medium">🟡 Medium</option>
                <option value="low">🟢 Low</option>
              </select>
            </div>
            <div class="col-md-2">
              <button type="submit" class="btn btn-primary btn-lg w-100">
                ➕ Add
              </button>
            </div>
          </form>
        </div>
      </div>

      <!-- Tasks by Status -->
      <ul class="nav nav-tabs mb-4" role="tablist">
        <li class="nav-item">
          <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#pending">
            📋 Pending <span class="badge bg-danger ms-2">7</span>
          </button>
        </li>
        <li class="nav-item">
          <button class="nav-link" data-bs-toggle="tab" data-bs-target="#in-progress">
            ⏳ In Progress <span class="badge bg-warning ms-2">2</span>
          </button>
        </li>
        <li class="nav-item">
          <button class="nav-link" data-bs-toggle="tab" data-bs-target="#completed">
            ✅ Completed <span class="badge bg-success ms-2">5</span>
          </button>
        </li>
      </ul>

      <div class="tab-content">
        
        <!-- Pending -->
        <div class="tab-pane fade show active" id="pending">
          <div class="list-group">
            
            <label class="list-group-item d-flex align-items-start gap-3 p-3 border-start border-danger border-4">
              <input class="form-check-input mt-1" type="checkbox">
              <div class="flex-grow-1">
                <h6 class="mb-1">Finish the sales report</h6>
                <p class="text-muted mb-2 small">Review Q1 data and generate charts</p>
                <span class="badge bg-danger">🔴 High</span>
                <span class="badge bg-light text-dark ms-2">Due: 05/04/2026</span>
              </div>
              <button class="btn btn-sm btn-outline-danger" type="button">Remove</button>
            </label>

            <label class="list-group-item d-flex align-items-start gap-3 p-3 border-start border-warning border-4">
              <input class="form-check-input mt-1" type="checkbox">
              <div class="flex-grow-1">
                <h6 class="mb-1">Study advanced TypeScript</h6>
                <p class="text-muted mb-2 small">Chapters 5-7 from the book "Pro TypeScript"</p>
                <span class="badge bg-warning">🟡 Medium</span>
                <span class="badge bg-light text-dark ms-2">Due: 10/04/2026</span>
              </div>
              <button class="btn btn-sm btn-outline-danger" type="button">Remove</button>
            </label>

            <label class="list-group-item d-flex align-items-start gap-3 p-3 border-start border-success border-4">
              <input class="form-check-input mt-1" type="checkbox">
              <div class="flex-grow-1">
                <h6 class="mb-1">Go grocery shopping</h6>
                <p class="text-muted mb-2 small">Milk, bread, meat, and fruits</p>
                <span class="badge bg-success">🟢 Low</span>
                <span class="badge bg-light text-dark ms-2">Due: 06/04/2026</span>
              </div>
              <button class="btn btn-sm btn-outline-danger" type="button">Remove</button>
            </label>

            <label class="list-group-item d-flex align-items-start gap-3 p-3 border-start border-danger border-4">
              <input class="form-check-input mt-1" type="checkbox">
              <div class="flex-grow-1">
                <h6 class="mb-1">Review API project code</h6>
                <p class="text-muted mb-2 small">Pull request #42 - validations and error handling</p>
                <span class="badge bg-danger">🔴 High</span>
                <span class="badge bg-light text-dark ms-2">Due: 08/04/2026</span>
              </div>
              <button class="btn btn-sm btn-outline-danger" type="button">Remove</button>
            </label>

            <label class="list-group-item d-flex align-items-start gap-3 p-3 border-start border-warning border-4">
              <input class="form-check-input mt-1" type="checkbox">
              <div class="flex-grow-1">
                <h6 class="mb-1">Update project documentation</h6>
                <p class="text-muted mb-2 small">README and contribution guide</p>
                <span class="badge bg-warning">🟡 Medium</span>
                <span class="badge bg-light text-dark ms-2">Due: 12/04/2026</span>
              </div>
              <button class="btn btn-sm btn-outline-danger" type="button">Remove</button>
            </label>

            <label class="list-group-item d-flex align-items-start gap-3 p-3 border-start border-success border-4">
              <input class="form-check-input mt-1" type="checkbox">
              <div class="flex-grow-1">
                <h6 class="mb-1">Organize retrospective meeting</h6>
                <p class="text-muted mb-2 small">Schedule with the team and prepare the agenda</p>
                <span class="badge bg-success">🟢 Low</span>
                <span class="badge bg-light text-dark ms-2">Due: 15/04/2026</span>
              </div>
              <button class="btn btn-sm btn-outline-danger" type="button">Remove</button>
            </label>

            <label class="list-group-item d-flex align-items-start gap-3 p-3 border-start border-warning border-4">
              <input class="form-check-input mt-1" type="checkbox">
              <div class="flex-grow-1">
                <h6 class="mb-1">Implement form validation</h6>
                <p class="text-muted mb-2 small">Frontend - real-time validation with visual feedback</p>
                <span class="badge bg-warning">🟡 Medium</span>
                <span class="badge bg-light text-dark ms-2">Due: 09/04/2026</span>
              </div>
              <button class="btn btn-sm btn-outline-danger" type="button">Remove</button>
            </label>

          </div>
        </div>

        <!-- In Progress -->
        <div class="tab-pane fade" id="in-progress">
          <div class="list-group">
            
            <label class="list-group-item d-flex align-items-start gap-3 p-3 border-start border-info border-4">
              <input class="form-check-input mt-1" type="checkbox">
              <div class="flex-grow-1">
                <h6 class="mb-1">Refactor Header component</h6>
                <p class="text-muted mb-2 small">Improve performance and responsiveness</p>
                <span class="badge bg-warning">🟡 Medium</span>
                <span class="badge bg-light text-dark ms-2">Due: 07/04/2026</span>
                <div class="progress mt-2" style="height: 20px;">
                  <div class="progress-bar bg-info" style="width: 60%;">60%</div>
                </div>
              </div>
              <button class="btn btn-sm btn-outline-danger" type="button">Remove</button>
            </label>

            <label class="list-group-item d-flex align-items-start gap-3 p-3 border-start border-info border-4">
              <input class="form-check-input mt-1" type="checkbox">
              <div class="flex-grow-1">
                <h6 class="mb-1">Fix login bugs</h6>
                <p class="text-muted mb-2 small">Issues #18 and #19 - timeout and redirect</p>
                <span class="badge bg-danger">🔴 High</span>
                <span class="badge bg-light text-dark ms-2">Due: 06/04/2026</span>
                <div class="progress mt-2" style="height: 20px;">
                  <div class="progress-bar bg-info" style="width: 40%;">40%</div>
                </div>
              </div>
              <button class="btn btn-sm btn-outline-danger" type="button">Remove</button>
            </label>

          </div>
        </div>

        <!-- Completed -->
        <div class="tab-pane fade" id="completed">
          <div class="list-group">
            
            <label class="list-group-item d-flex align-items-start gap-3 p-3 border-start border-success border-4">
              <input class="form-check-input mt-1" type="checkbox" checked>
              <div class="flex-grow-1">
                <h6 class="mb-1"><del>Prepare results presentation</del></h6>
                <p class="text-muted mb-2 small">Slides and notes for the CEO</p>
                <span class="badge bg-success">✅ Completed</span>
                <span class="badge bg-light text-dark ms-2">Completed on: 04/04/2026</span>
              </div>
              <button class="btn btn-sm btn-outline-danger" type="button">Remove</button>
            </label>

            <label class="list-group-item d-flex align-items-start gap-3 p-3 border-start border-success border-4">
              <input class="form-check-input mt-1" type="checkbox" checked>
              <div class="flex-grow-1">
                <h6 class="mb-1"><del>Set up CI/CD pipeline</del></h6>
                <p class="text-muted mb-2 small">GitHub Actions and automatic deploy</p>
                <span class="badge bg-success">✅ Completed</span>
                <span class="badge bg-light text-dark ms-2">Completed on: 03/04/2026</span>
              </div>
              <button class="btn btn-sm btn-outline-danger" type="button">Remove</button>
            </label>

            <label class="list-group-item d-flex align-items-start gap-3 p-3 border-start border-success border-4">
              <input class="form-check-input mt-1" type="checkbox" checked>
              <div class="flex-grow-1">
                <h6 class="mb-1"><del>Write unit tests</del></h6>
                <p class="text-muted mb-2 small">80% project coverage</p>
                <span class="badge bg-success">✅ Completed</span>
                <span class="badge bg-light text-dark ms-2">Completed on: 02/04/2026</span>
              </div>
              <button class="btn btn-sm btn-outline-danger" type="button">Remove</button>
            </label>

            <label class="list-group-item d-flex align-items-start gap-3 p-3 border-start border-success border-4">
              <input class="form-check-input mt-1" type="checkbox" checked>
              <div class="flex-grow-1">
                <h6 class="mb-1"><del>Back up the database</del></h6>
                <p class="text-muted mb-2 small">Full and incremental backup</p>
                <span class="badge bg-success">✅ Completed</span>
                <span class="badge bg-light text-dark ms-2">Completed on: 01/04/2026</span>
              </div>
              <button class="btn btn-sm btn-outline-danger" type="button">Remove</button>
            </label>

            <label class="list-group-item d-flex align-items-start gap-3 p-3 border-start border-success border-4">
              <input class="form-check-input mt-1" type="checkbox" checked>
              <div class="flex-grow-1">
                <h6 class="mb-1"><del>Review client proposal</del></h6>
                <p class="text-muted mb-2 small">Technical analysis and budget</p>
                <span class="badge bg-success">✅ Completed</span>
                <span class="badge bg-light text-dark ms-2">Completed on: 31/03/2026</span>
              </div>
              <button class="btn btn-sm btn-outline-danger" type="button">Remove</button>
            </label>

          </div>
        </div>

      </div>

      <!-- Summary Stats -->
      <div class="row mt-5">
        <div class="col-md-4 mb-3">
          <div class="card border-0 shadow-sm bg-light">
            <div class="card-body text-center">
              <h5 class="card-title">Pending</h5>
              <h2 class="display-6 text-danger">7</h2>
              <small class="text-muted">Waiting for action</small>
            </div>
          </div>
        </div>
        <div class="col-md-4 mb-3">
          <div class="card border-0 shadow-sm bg-light">
            <div class="card-body text-center">
              <h5 class="card-title">In Progress</h5>
              <h2 class="display-6 text-info">2</h2>
              <small class="text-muted">Currently being worked on</small>
            </div>
          </div>
        </div>
        <div class="col-md-4 mb-3">
          <div class="card border-0 shadow-sm bg-light">
            <div class="card-body text-center">
              <h5 class="card-title">Completed</h5>
              <h2 class="display-6 text-success">5</h2>
              <small class="text-muted">Finished</small>
            </div>
          </div>
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="d-flex gap-2 mt-5 mb-5">
        <button class="btn btn-primary btn-lg flex-grow-1">
          💾 Save Tasks
        </button>
        <button class="btn btn-outline-secondary btn-lg flex-grow-1">
          🔄 Reorder
        </button>
        <button class="btn btn-outline-danger btn-lg flex-grow-1">
          🗑️ Clear Completed
        </button>
      </div>

    </div>
  </div>
</div>

<style>
  .list-group-item {
    cursor: pointer;
    transition: background-color 0.2s;
  }
  
  .list-group-item:hover {
    background-color: #f8f9fa;
  }

  .list-group-item input[type="checkbox"]:checked ~ div h6 {
    opacity: 0.7;
  }

  .nav-tabs .nav-link.active {
    border-bottom-width: 3px;
    font-weight: 600;
  }

  .border-start {
    border-left-width: 6px !important;
  }

  .progress {
    border-radius: 0.25rem;
  }
</style>

<%- include('includes/footer') %>
