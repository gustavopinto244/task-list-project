<%- include('includes/head') %>
<%- include('includes/nav') %>

<div class="hero-shell">
  <div class="hero-glow hero-glow-left"></div>
  <div class="hero-glow hero-glow-right"></div>

  <main class="container py-5 py-lg-6">
    <div class="row align-items-center min-vh-100 py-4">
      <div class="col-lg-7">
        <span class="eyebrow">Learning project</span>
        <h1 class="display-3 hero-title mb-4">Welcome to Task List Project</h1>
        <p class="lead hero-copy mb-4">
          This project was created to practice web development with Node.js, Express, EJS, and MongoDB.
          Here I track the evolution of the system, test ideas, and turn learning into a real application.
        </p>

        <div class="d-flex flex-wrap mb-4">
          <a class="btn btn-dark btn-lg px-4 mr-3 mb-2" href="https://www.linkedin.com/in/gustavo-pinto-da-concei%C3%A7%C3%A3o/" target="_blank" rel="noreferrer">
            View LinkedIn
          </a>
          <a class="btn btn-outline-dark btn-lg px-4 mb-2" href="https://github.com/gustavopinto244" target="_blank" rel="noreferrer">
            View GitHub
          </a>
        </div>

        <div class="hero-note">
          <strong>Goal:</strong> Learn new ways of appling MVC.
        </div>
      </div>

      <div class="col-lg-5 mt-5 mt-lg-0">
        <div class="card hero-card border-0 shadow-lg">
          <div class="card-body p-4 p-lg-5">
            <div class="d-flex align-items-center justify-content-between mb-4">
              <div>
                <small class="text-uppercase text-muted letter-spacing">Overview</small>
                <h2 class="h3 mb-0">What you'll find here</h2>
              </div>
              <span class="badge bg-dark rounded-pill px-3 py-2">Learning</span>
            </div>

            <div class="feature-item">
              <div class="feature-bullet"></div>
              <div>
                <h3 class="h6 mb-1">Task interface</h3>
                <p class="text-muted mb-0">A dedicated space to manage lists and track progress.</p>
              </div>
            </div>

            <div class="feature-item">
              <div class="feature-bullet"></div>
              <div>
                <h3 class="h6 mb-1">Evolving back-end</h3>
                <p class="text-muted mb-0">A structure built to explore routes, controllers, models and views.</p>
              </div>
            </div>

            <div class="feature-item mb-0">
              <div class="feature-bullet"></div>
              <div>
                <h3 class="h6 mb-1">Portfolio and study</h3>
                <p class="text-muted mb-0">A project to practice, show progress, and share what I'm learning.</p>
              </div>
            </div>

            <a class="btn btn-primary btn-block btn-lg mt-4" href="/tasks/index">Open tasks</a>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>

<style>
  body {
    background: var(--primary-color);
  }
  .badge {
    color: white;
  }
  .hero-shell {
    position: relative;
    overflow: hidden;
    min-height: calc(100vh - 56px);
    background:
      radial-gradient(circle at top left, rgba(255, 255, 255, 0.2), transparent 32%),
      radial-gradient(circle at bottom right, rgba(255, 255, 255, 0.14), transparent 34%),
      linear-gradient(180deg, rgba(9, 48, 56, 0.08) 0%, rgba(17, 86, 102, 0.1) 100%);
  }

  .hero-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(20px);
    opacity: 0.55;
    pointer-events: none;
  }

  .hero-glow-left {
    width: 220px;
    height: 220px;
    left: -60px;
    top: 80px;
    background: rgba(255, 255, 255, 0.22);
  }

  .hero-glow-right {
    width: 280px;
    height: 280px;
    right: -100px;
    bottom: 20px;
    background: rgba(9, 48, 56, 0.22);
  }

  .eyebrow {
    display: inline-block;
    margin-bottom: 1rem;
    padding: 0.45rem 0.8rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.82);
    color: #0f4d5b;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-title {
    color: black;
    line-height: 0.95;
    font-weight: 800;
  }

  .hero-copy {
    max-width: 38rem;
    color: rgba(0, 0, 0, 0.92);
    font-size: 1.15rem;
  }

  .hero-note {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    padding: 0.85rem 1rem;
    border-left: 4px solid #0f4d5b;
    border-radius: 0.75rem;
    background: rgba(255, 255, 255, 0.16);
    color: black;
    box-shadow: 0 12px 35px rgba(9, 48, 56, 0.25);
  }

  .hero-card {
    border-radius: 1.5rem;
    backdrop-filter: blur(8px);
    background: rgba(255, 255, 255, 0.93);
  }

  .letter-spacing {
    letter-spacing: 0.12em;
  }

  .feature-item {
    display: flex;
    gap: 0.9rem;
    margin-bottom: 1.1rem;
    padding-bottom: 1.1rem;
    border-bottom: 1px solid rgba(20, 33, 61, 0.08);
  }

  .feature-item:last-of-type {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .feature-bullet {
    width: 0.8rem;
    height: 0.8rem;
    margin-top: 0.35rem;
    border-radius: 999px;
    background: var(--primary-color-darker);
    flex: 0 0 auto;
  }

  @media (max-width: 991.98px) {
    .hero-shell {
      min-height: auto;
    }

    .hero-title {
      font-size: 3rem;
    }
  }

  @media (max-width: 575.98px) {
    .hero-title {
      font-size: 2.4rem;
    }

    .hero-copy {
      font-size: 1.05rem;
    }
    
  }
</style>

<%- include('includes/footer') %>
